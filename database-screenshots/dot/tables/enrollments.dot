digraph single_table {
  graph [rankdir=TB, fontsize=18];
  node [shape=plain, fontname="Arial"];
  "enrollments" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>enrollments</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">client_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → app_users.id</TD></TR><TR><TD ALIGN="LEFT">course_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → courses.id</TD></TR><TR><TD ALIGN="LEFT">teacher_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → app_users.id</TD></TR><TR><TD ALIGN="LEFT">enrolled_at</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">completed_at</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">next_due_at</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">character varying(32)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">notes</TD><TD ALIGN="LEFT">character varying(2000)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">group_name</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
}